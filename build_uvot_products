def setup_data_directories():
    """
    setup for data and save directories/also downloads said areas if asked, gives
    (data_directory, save_directory) or (None, None) if user cancels
    """
    global DATA_DIRECTORY, SAVE_DIRECTORY
    print("\n" + "="*70)
    print("SWIFT UVOT DATA SETUP")
    print("="*70)
    
    # Ask if they have existing data they would rather use to skip this, Useful for testing other code.
    print("\nDo you have SWIFT data already downloaded?")
    print("  1. Yes - I have existing data")
    print("  2. No - I need to download new data")
    
    while True:
        choice = input("\nEnter your choice (1 or 2): ").strip()
        if choice in ['1', '2']:
            break
        print("Invalid choice. Please enter 1 or 2.")
    
    # Initialize Tkinter for file pathings coming up.
    root = tk.Tk()
    root.withdraw()
    
    if choice == '1':
        ###################################################################### 
        # OPTION 1: Use data you already have
        ###################################################################### 
        print("\n" + "-"*70)
        print("SELECT EXISTING DATA DIRECTORY")
        print("-"*70)
        print("Please select the folder containing your data.")
        
        data_directory = filedialog.askdirectory(title="Select Existing SWIFT Data Directory") # Alot of this is user fluff which will look nice.
        
        if not data_directory:
            print("No directory selected. Aborting.")
            return None, None
        
        print(f"Data Directory: {data_directory}")
        
        # Ask for save directory
        print("\n" + "-"*70)
        print("SELECT SAVE DIRECTORY FOR RESULTS")
        print("-"*70)
        print("Please select where you want to save analysis results...")
        
        save_directory = filedialog.askdirectory(title="Select Save Directory for Results")
        
        if not save_directory:
            print("No save directory selected. Using data directory as default.")
            save_directory = data_directory
        
        print(f"Save Directory: {save_directory}")
        
        ###################################################################### 
        # Save Paths global
        DATA_DIRECTORY = data_directory
        SAVE_DIRECTORY = save_directory

        return data_directory, save_directory
    
    else:
        ###################################################################### 
        # OPTION 2: Download It new
        ######################################################################  
        print("\n" + "-"*70)
        print("DOWNLOAD NEW SWIFT DATA")
        print("-"*70)
        
        # Get search parameters, As it stands I am using old logic that find it off location. I know 100% theres a way to do it off the name of the object
        # That I think would need SIMBAD to do, which will then give you the location. That way would proably be better then this since its more user freindly, but I already had this and it works.
        print("\nEnter the coordinates and search radius:")

        # For testing SXP5.05 = (ra='14.259118', dec='-72.432064', radius=0.18)
        while True:
            try:
                ra = input("Right Ascension (decimal degrees): ").strip()
                ra = float(ra)
                break
            except ValueError:
                print("Invalid input. Please enter a number.")
        
        while True:
            try:
                dec = input("Declination (decimal degrees): ").strip()
                dec = float(dec)
                break
            except ValueError:
                print("Invalid input. Please enter a number.")
        
        while True:
            try:
                radius = input("Search radius (degrees): ").strip()
                radius = float(radius)
                break
            except ValueError:
                print("Invalid input. Please enter a number.")
        
        # Query the database
        print(f"\n Searching for observations at RA={ra}, Dec={dec}, Radius={radius}°...")
        query = ObsQuery(ra=str(ra), dec=str(dec), radius=radius)
        
        total_obs = len(query)
        
        if total_obs == 0:
            print("No observations found with these parameters.")
            return None, None
        
        # Display results
        print(f"\n{'='*70}")
        print(f"FOUND {total_obs} OBSERVATION(S)")
        print(f"{'='*70}")
        
        # Show first few observations as preview to the data
        preview_count = min(10, total_obs)
        print(f"\nPreview of first {preview_count} observation(s):")
        for i, q in enumerate(list(query)[:preview_count], start=1):
            print(f"  {i}. ObsID: {q.obsid} | Date: {q.begin}")
        
        if total_obs > preview_count:
            print(f"  ... and {total_obs - preview_count} more")
        
        # Confirm download
        print(f"\n This will download {total_obs} observation(s) with UVOT data, This can take a while and use alot of storage.")
        confirm = input("Do you want to proceed with the download? (yes/no): ").strip().lower()
        
        if confirm not in ['yes', 'y']:
            print("Download cancelled.")
            return None, None
        
        # Select download directory
        print("\n" + "-"*70)
        print("SELECT DOWNLOAD DIRECTORY")
        print("-"*70)
        print("Please select where you want to download the SWIFT data...")
        
        data_directory = filedialog.askdirectory(title="Select Download Directory")
        
        if not data_directory:
            print("No directory selected. Aborting.")
            return None, None
        
        print(f"Data will be downloaded to: {data_directory}")
        
        # Select save directory for results
        print("\n" + "-"*70)
        print("SELECT SAVE DIRECTORY FOR RESULTS")
        print("-"*70)
        print("Please select where you want to save analysis results...")
        
        save_directory = filedialog.askdirectory(title="Select Save Directory for Results")
        
        if not save_directory:
            print("No save directory selected. Using download directory as default.")
            save_directory = data_directory
        
        print(f"Save Directory: {save_directory}")
        
        # Create base directory
        os.makedirs(data_directory, exist_ok=True) #Safty code, makes sure  the  folder actualy exists and makes it if it doesnt. I know sometimes some devices dont do an excelent job of knowing where a file is or isnt esspecially when a person inputs it.
        
        # Download the data
        print(f"\n{'='*70}")
        print("DOWNLOADING DATA")
        print(f"{'='*70}")
        
        for i, q in enumerate(query, start=1):
            # Create unique folder for this observation
            start_time_str = str(q.begin).replace(":", "-").replace(" ", "_")
            obs_dir = os.path.join(data_directory, f"{q.obsid}_{start_time_str}")
            os.makedirs(obs_dir, exist_ok=True)
            
            # Skip if already downloaded
            if os.listdir(obs_dir):
                print(f"[{i}/{total_obs}] ObsID {q.obsid} already exists, skipping...")
                continue
            
            # Download
            print(f"[{i}/{total_obs}] Downloading ObsID {q.obsid} (Date: {q.begin})...")
            try:
                Data(obsid=q.obsid, uvot=True, clobber=True, outdir=obs_dir)
                print(f"Successfully downloaded to {obs_dir}")
            except Exception as e:
                print(f"Failed to download: {e}")
        
        print(f"\n{'='*70}")
        print("DOWNLOAD COMPLETE")
        print(f"{'='*70}")
        print(f"Total observations downloaded: {total_obs}")
        print(f"Data location: {data_directory}")

        ###################################################################### 
        # Save Paths global
        ###################################################################### 
        DATA_DIRECTORY = data_directory
        SAVE_DIRECTORY = save_directory

        return data_directory, save_directory





