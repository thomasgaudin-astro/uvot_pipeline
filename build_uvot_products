def run_heasoft_command(command):
    print(f"\n[SYSTEM]: Running HEASOFT command...")
    
    if HEASOFT_BACKEND == "wsl":
        # --- This is YOUR working logic ---
        full_cmd = f"conda activate henv && {command}"
        result = subprocess.run(
            ["wsl", "bash", "-ic", full_cmd],
