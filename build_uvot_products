        )
        
    elif HEASOFT_BACKEND == "native":
        # --- This is the MAC lane ---
        full_cmd = f"source $HEADAS/headas-init.sh && {command}"
        result = subprocess.run(
            ["bash", "-lc", full_cmd],
            text=True,
            capture_output=True,
        )
