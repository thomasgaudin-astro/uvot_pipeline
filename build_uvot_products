# The final command that will one day run everything for download to  cleanup to graphs.
def run_uvot_pipeline():
    
    print("\n" + "="*70)
    print("SWIFT UVOT COMPLETE PIPELINE")
    print("="*70)
    
    ####################################################################################
    #1: SETUP DATA DIRECTORIES
    print("\n[PIPELINE STEP 1/3] Setting up data directories...")
    
    data_dir, save_dir = setup_data_directories()
    
    if data_dir is None or save_dir is None:
        print("\n❌ruh-roh: Setup failed.")
        return
    
    ####################################################################################
    #secound thing to do: Run Cleanup (UVOTDETECT, SMEARED, IAC, ORPHAN)
    print("\n[PIPELINE STEP 2/3] Running data cleanup...")
    
    results = clean_up_data(
        automation_mode=True,
        base_path=data_dir,
        save_path=save_dir
    )
    
    if results is None or results['observations_table'] is None:
        print("\n❌ruh-roh: Cleanup failed.")
        return
    
    obs_table = results['observations_table']
    
    ####################################################################################
    #Big 3: RUN AUTOMATED ASPECT CORRECTION
    print("\n[PIPELINE STEP 3/3] Running automated aspect correction...")
    
    # Ask user for parameters
    print("\nAspect Correction Parameters:")
    
    sb_needed = True
    while sb_needed:
        side_buffer = input("  Distance from center to include (arcmin): [7] ")
        if side_buffer == "":
            side_buffer = 7
            sb_needed = False
        else:
            try:
                side_buffer = int(side_buffer)
                sb_needed = False
            except:
                print("  Please pick a valid integer.")
    
    ns_needed = True
    while ns_needed:
        num_stars = input("  Number of stars to use: [50] ")
        if num_stars == "":
            num_stars = 50
            ns_needed = False
        else:
            try:
                num_stars = int(num_stars)
                ns_needed = False
            except:
                print("  Please pick a valid integer.")
    
    # Run aspect correction
    aspectnone_dict, aspectnone_tiles_dict = automated_aspect_correction(
        obs_table=obs_table,
        base_path=data_dir,
        save_path=save_dir,
        side_buffer=side_buffer,
        num_stars=num_stars
    )
    
    # Check if we need another pass
    if aspectnone_dict and sum(aspectnone_dict.values()) > 0:
        print(f"\n⚠️  {sum(aspectnone_dict.values())} frames still need correction")
        
        ga = False
        while ga == False:
            go_again = input("\nTry again with different parameters? [Y/N]: ")
            
            if go_again.upper() == 'Y':
                print("\nStarting another correction pass...")
                
                # Reload updated obs_table
                table_path = os.path.join(save_dir, "observations_table.csv")
                obs_table = pd.read_csv(table_path)
                
                # Run again with new parameters
                aspectnone_dict, aspectnone_tiles_dict = automated_aspect_correction(
                    obs_table=obs_table,
                    base_path=data_dir,
                    save_path=save_dir,
                    side_buffer=side_buffer,
                    num_stars=num_stars
                )
                
                if sum(aspectnone_dict.values()) == 0:
                    print("\n✓ All corrections complete!")
                    ga = True
                
            elif go_again.upper() == 'N':
                print("\nExiting pipeline. Saving bad frames report...")
                
                # Save bad frames CSV (like original)
                bad_frames = pd.DataFrame.from_dict(
                    aspectnone_tiles_dict,
                    orient='index'
                )
                bad_frames_path = os.path.join(save_dir, 'bad_frames.csv')
                bad_frames.to_csv(bad_frames_path)
                
                print(f"✓ Bad frames report saved to: {bad_frames_path}")
                ga = True
            else:
                print("Please pick a valid option. [Y/N]")
    
    ###########################################################################
    # FINAL SUMMARY

    print("\n" + "="*70)
    print("PIPELINE COMPLETE")
    print("="*70)
    print(f"Data directory: {data_dir}")
    print(f"Save directory: {save_dir}")
    print("\nGenerated files:")
    print(f"  - observations_table.csv")
    print(f"  - workload_summary.csv")
    print(f"  - orphan_frames/ (if applicable)")
    if aspectnone_dict and sum(aspectnone_dict.values()) > 0:
        print(f"  - bad_frames.csv")
    print("="*70)
